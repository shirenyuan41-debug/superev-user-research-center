PORT=3001
NODE_ENV=development
SESSION_SECRET=change_me_to_a_long_random_string
SESSION_COOKIE_NAME=superev_sid
SESSION_IDLE_TIMEOUT_HOURS=12
FRONTEND_ORIGIN=http://127.0.0.1:3000
FRONTEND_ORIGINS=http://127.0.0.1:3000
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=superev_research_center
MYSQL_USER=superev_app
MYSQL_PASSWORD=change_me
MYSQL_CONNECTION_LIMIT=10

MYSQL_INIT_HOST=127.0.0.1
MYSQL_INIT_PORT=3306
MYSQL_INIT_ROOT_USER=root
MYSQL_INIT_ROOT_PASSWORD=change_me
MYSQL_INIT_DATABASE=superev_research_center
MYSQL_INIT_APP_USER=superev_app
MYSQL_INIT_APP_PASSWORD=change_me

ADMIN_ACCOUNT=admin@superev.com
ADMIN_NAME=系统管理员
ADMIN_PASSWORD=change_me
ADMIN_ROLE=管理员

LLM_PROVIDER=gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# 兼容旧配置时仍可保留以下字段，系统会把它们当作 DeepSeek 的兼容别名
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=your_deepseek_api_key
# LLM_MODEL=deepseek-chat

STORAGE_ROOT=./storage/source-documents
DOCUMENT_STORAGE_MODE=local
DOCUMENT_MAX_FILE_SIZE_MB=10
