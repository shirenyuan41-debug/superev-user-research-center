{
  "name": "superev-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/run-backend.mjs dev",
    "build": "tsc -p tsconfig.json",
    "start": "node ../scripts/run-backend.mjs start",
    "db:init": "tsx src/scripts/init-db.ts",
